#!/usr/bin/env nu

# Get status of all your checks
def main [--json] {
  if not (config-file | path exists) {
    error make {
      msg: "Not configured yet. Run `set-key` subcommand first."
    }
  }
  let api_key = config-file | open | get api_key
  let raw_results = http get --headers [X-Api-Key $api_key] https://healthchecks.io/api/v3/checks/
  if $json {
    $raw_results | to json | print
    return
  }

  (
    $raw_results
    | get checks
    | each {
      {
        name: $in.name
        status: ($in.status | into ping-status)
        last_ping: ($in.last_ping | into ping-datetime)
      }
    }
    | sort-by last_ping --reverse
    | table --index false
  )
}

# Set your Healthchecks.io read-only API key
def "main set-key" [] {
  let api_key = input --suppress-output "Enter API key: "
  mkdir (config-dir)
  {
    api_key: $api_key
  } | save (config-file)
}

def config-file []: nothing -> string {
  config-dir | path join config.toml
}

def config-dir []: nothing -> string {
  (
    $env
    | get --optional XDG_CONFIG_HOME
    | default $"($env.HOME)/.config"
    | path join hcio
  )
}

def "into ping-datetime" []: any -> datetime {
  if ($in | is-empty) {
    null
  } else {
    $in | into datetime
  }
}

def "into ping-status" [] : string -> string {
  match $in {
    "up" => { $"🟢 (ansi green)up(ansi reset)" }
    "down" => { $"🔴 (ansi red)DOWN(ansi reset)" }
    "grace" => { $"🟡 (ansi yellow)grace(ansi reset)" }
    "paused" => { $"⚫️ (ansi dark_gray)paused(ansi reset)" }
    $x => { $x }
  }
}
