#!/usr/bin/env nu


# Move ical / vdirsyncer events to an "archive" calendar
#
# Example usage:
#
#     # archive anything that's older than 13 years
#     ical-archive ~/your_calendar ~/archive_calendar 4745day
def main [
  source: string   # directory containing your source vdirsyncer calendar
  dest: string     # directory containing your archived events
  max_age: string  # a duration value like "365day", where any older events get archived
  --commit         # actually make changes
] {
  let max_age = $max_age | into duration
  let cutoff = (date now) - $max_age
  let to_archive = (
    ls $source
    | get name
    | where { ($in | path parse).extension == ics }
    | path expand
    | parse-events
    | where { $in.begin < $cutoff }
    | where { $in.end | is-not-empty }
    | where { $in.end < $cutoff }
    | sort-by begin end
    | each {
      upsert begin ($in.begin | into yyyy-mm-dd)
      | upsert end ($in.end | into yyyy-mm-dd)
    }
  )

  $to_archive | select summary begin end | print

  if $commit {
    mkdir $dest
    $to_archive | each { mv $in.file $dest }
    $"Archived ($to_archive | length) events." | print
  } else {
    $"Would archive ($to_archive | length) events total." | print
    "Add `--commit` to make changes." | print
  }

  ignore
}

def parse-events []: list<string> -> list<record> {
  each {
    let path = $in
    let full_contents = $path | open | lines | each { str trim }

    mut event_contents = []
    mut keep = false
    for line in $full_contents {
      if ($line == "BEGIN:VEVENT") {
        $keep = true
        continue
      } else if ($line == "END:VEVENT") {
        break
      }

      if $keep {
        $event_contents ++= [$line]
      }
    }

    # make immutable
    let event_contents = $event_contents

    let begin = (
      $event_contents
      | extract-first-value "DTSTART;{value}"
      | default { $event_contents | extract-first-value "DTSTART:{value}" }
      | parse-date
    )

    let end = (
      $event_contents
      | extract-first-value "DTEND;{value}"
      | default { $event_contents | extract-first-value "DTEND:{value}" }
      | default { $event_contents | extract-first-value "RRULE:{discard};UNTIL={value}" }
      | parse-date
    )

    {
      summary: ($event_contents | extract-first-value "SUMMARY:{value}")
      begin: $begin
      end: $end
      file: $path
    }
  }
}

def extract-first-value [pattern: string] {
  parse $pattern | get value | first
}

def parse-date []: any -> datetime {
  # examples to parse:
  #
  # - TZID=America/Chicago:20170620T180000
  # - TZID=Europe/Berlin:20190626T160000
  # - VALUE=DATE:20201114
  # - 20091114T000000Z
  #
  let raw = $in
  if ($raw | is-empty) {
    return null
  }

  let with_tzid = $raw | parse 'TZID={tzid}:{timestamp}' | first
  if ($with_tzid | get --optional timestamp | is-not-empty) {
    return ($with_tzid.timestamp | into datetime)
  }

  let with_value = $raw | parse 'VALUE=DATE:{timestamp}' | first
  if ($with_value | get --optional timestamp | is-not-empty) {
    return ($with_value.timestamp | into datetime)
  }

  return ($raw | into datetime)
}

def "into yyyy-mm-dd" []: any -> string {
  let date = $in
  if ($date | is-empty) {
    "NA"
  } else {
    $date | format date %Y-%m-%d
  }
}
