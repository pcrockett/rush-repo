#!/usr/bin/env nu

let XDG_STATE_HOME = (
  $env
  | get --optional XDG_STATE_HOME
  | default $"($env.HOME)/.local/state"
)
let STATE_DIR = $"($XDG_STATE_HOME)/tw"
let TEMPLATE_FILE_PATH = $"($STATE_DIR)/template.toml"
let DECAY_STATE_FILE = $"($STATE_DIR)/decay.toml"

# Taskwarrior wrapper that adds my own custom functionality
def main [
  ...args: string       # args to pass directly to `task`
] {
  auto-decay
  ^task ...$args
}

# Add a task
def "main add" [...args: string] {
  let now = date now | date to-timezone UTC
  let template = (get-template $now)
  if ($template.add.expire > $now) {
    ^task add ...$template.add.args ...$args
  } else {
    ^task add ...$args
  }
}

# Interactively edit task notes with your `$EDITOR`
def "main notes" [
  task: string      # Task ID
] {
  edit $task "notes"
}

# Define a parameter template to include in all `add` commands
def "main template add" [
  --ttl(-t) = 10min   # how long the template should remain in effect
  --clear(-c)         # clear the current template
  ...args: string     # the `task` parameters you want to add to the template
] {
  if $clear {
    rm --force $TEMPLATE_FILE_PATH
    return
  }

  let now = date now | date to-timezone UTC
  let config = (
    get-template $now
    | update add.expire (($now + $ttl) | serialize-date)
    | if ($args | length) > 0 {
      update add.args $args
    } else {
      # no args were specified. leave the existing config args (if any) alone, and just
      # update the ttl.
      $in
    }
  )
  mkdir $STATE_DIR
  $config | save --force $TEMPLATE_FILE_PATH
  ignore
}

# Taskwarrior sync, with optional `vdirsyncer` and `pueue` integration
def "main sync" [
  --wait(-w)        # wait for pueue tasks to finish before returning
  ...args: string   # args to be passed to `task sync`
]: nothing -> nothing {
  auto-decay
  const PUEUE_GROUP = {
    name: "tw-sync"
    parallel: 2
  }
  let tw_sync_id = [task sync ...$args] | enqueue-cmd $PUEUE_GROUP
  let cal_sync_id = if (which vdirsyncer | is-not-empty) {
    [vdirsyncer sync] | enqueue-cmd $PUEUE_GROUP
  } else {
    null
  }

  let sync_task_ids = (
    [$tw_sync_id $cal_sync_id] | where { $in != null }
  )

  if ($sync_task_ids | is-not-empty) {
    if $wait {
      # can safely assume pueue is installed at this point, since we have task IDs
      ^pueue wait --group $PUEUE_GROUP.name
      ^pueue log ...$sync_task_ids
    } else {
      $"Sync tasks enqueued: run `pueue log ($sync_task_ids | str join ' ')` for details." | print
    }
  }
}

# Recompute task `decay_coeff` UDA using the `decay` date
def "main decay" [
  --verbose(-v)
] {
  let now = date now | date to-timezone UTC
  let decay_updates = (
    ^task rc.gc=0 status:pending decay.any: export
    | from json
    | each {|task|
      {
        uuid: $task.uuid
        decay: {
          begin: ($task.entry | into datetime)
          end: ($task.decay | into datetime)
          coeff: ($task.decay_coeff? | default "0" | into int)
        }
      }
    }
    | each {|task|
      let total_duration = $task.decay.end - $task.decay.begin
      if (($total_duration | into int) < 0) {
        error make { msg: $"task ($task.uuid) has decay end date before creation date." }
      }
      let time_passed = $now - $task.decay.begin
      if (($time_passed | into int) < 0) {
        error make { msg: $"task ($task.uuid) begins AFTER the current time." }
      }
      let decay_ratio = ($time_passed / $total_duration)
      let decay = [($decay_ratio * 10 | into int) 10] | math min

      {
        uuid: $task.uuid
        decay_coeff: {
          old: $task.decay.coeff
          new: $decay
        }
      }
    }
    | where { $in.decay_coeff.old != $in.decay_coeff.new }
  )

  (
    $decay_updates
    | each {|t|
      ^task $t.uuid modify $"decay_coeff:($t.decay_coeff.new)"
    }
  )

  $now | update-decay-timestamp

  print --stderr $"Updated ($decay_updates | length) tasks."

  if $verbose {
    $decay_updates
  }
}

# Interactively edit task attributes with your `$EDITOR`
def edit [
  task: string       # Task ID
  attribute: string  # Name of the attribute to edit
] {
  let temp_dir = mktemp --directory
  let cleanup = {
    cd -;
    rm --recursive --force $temp_dir;
  }
  cd $temp_dir

  try {
    safe-exec [task _get $"($task).($attribute)"] | save attribute.md
    ^$env.EDITOR attribute.md
    safe-exec [task $task modify $"($attribute):(open --raw attribute.md | str trim)"]
  } catch {|err|
    do $cleanup
    error make $err
  }

  do $cleanup
}

def safe-exec [$args: list<string>]: nothing -> string {
  do { ^$args }
  | complete
  | match $in {
    {exit_code: 0} => { $in.stdout }
    {exit_code: $x} => {
      let result = $in
      error make {
        msg: $"Exited with code ($x): ($args | str join ' ')\n\n($result | table)"
      }
    }
  }
}

def get-template [now: datetime]: nothing -> record {
  let raw_template = (
    $TEMPLATE_FILE_PATH
    | open-or-default {
      add: {
        expire: ($now | serialize-date)
        args: []
      }
    }
  )
  # convert expiration string to a datetime
  $raw_template | update add.expire ($raw_template.add.expire | into datetime)
}

# Enqueue a command with `pueue`, if installed. If not, just run the command.
# Command should be piped in as an array of strings.
# Returns pueue task ID, or null if pueue isn't installed.
def enqueue-cmd [
  group: record<name: string, parallel: int>
]: list<string> -> int {

  let command = $in
  let group_name = $group.name
  let parallel = $group | get --optional parallel | default 1

  if (which pueue | is-empty) {
    # Pueue not installed. Just run the command directly.
    if ($command | is-not-empty) {
      ^$command | print
    }
    return null
  }

  let group_exists = (
    ^pueue group --json
    | from json
    | columns
    | find $group_name
    | is-not-empty
  )
  if (not $group_exists) {
    ^pueue group add --parallel $parallel $group_name
  }

  let task_id = if ($command | is-not-empty) {
    ^pueue add --group $group_name --print-task-id -- ...$command | into int
  } else {
    null
  }

  $task_id
}

# ensure `tw decay` gets executed occasionally
def auto-decay []: nothing -> nothing {
  let now = date now | date to-timezone UTC
  let interval = (
    $env.TW_AUTO_DECAY_INTERVAL_MIN?
    | default "720"  # 12 hours
    | into duration --unit min
  )
  if (($interval | into int) < 0) {
    return  # auto-decay disabled
  }

  let decay_state = (
    $DECAY_STATE_FILE
    | open-or-default { last_decay: null }
  )
  let last_decay = (
    try {
      $decay_state.last_decay | into datetime
    } catch {
      $now - $interval  # will trigger an auto-decay below
    }
  )
  if (($now - $last_decay) >= $interval) {
    print --stderr "Computing decay..."
    main decay  # will update decay timestamp
  }
  ignore
}

def update-decay-timestamp []: datetime -> nothing {
  let instant = $in
  mkdir $STATE_DIR
  (
    { last_decay: ($instant | serialize-date ) }
    | save --force $DECAY_STATE_FILE
  )
}

# read a file, and if it doesn't exist, return a default value
def open-or-default [default: any]: string -> any {
  try {
    open
  } catch { |err|
    let code = ($err.json? | default "{}" | from json).code?
    if ($code == nu::shell::io::file_not_found) {
      $default
    } else {
      error make $err
    }
  }
}

def serialize-date []: datetime -> string {
  date to-timezone UTC | format date "%+"
}
